# AwardWallet API credentials
# Get these from: https://business.awardwallet.com/profile/api
#
# IMPORTANT: Whitelist your IP at https://business.awardwallet.com/profile/api
# otherwise all requests will be rejected with IP_DENIED

api_key: "your-api-key-here"
user_id: "your-user-id-here"

# To find your user_id, run:
# curl -s -H "X-Authentication: your-api-key" \
#   "https://business.awardwallet.com/api/export/v1/connectedUser" | jq '.'
#
# This lists all connected users in your business account, each with their own user_id.
# You can query different users to see their family members' / travel companions' balances.